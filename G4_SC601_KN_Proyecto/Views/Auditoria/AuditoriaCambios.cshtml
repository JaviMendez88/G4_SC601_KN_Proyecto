
@model List<G4_SC601_KN_Proyecto.EntityFramework.auditoria>

@{
    ViewBag.Title = "Auditoría de Cambios";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4">
    <h2 class="mb-3 text-gray-800">
        <i class="fas fa-history text-primary"></i> Auitoría de Cambios 
    </h2>
    <p class="text-muted">Registro histórico de las modificaciones realizadas en la base de datos.</p>


    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold" style="color: #0056b3;">
                <i class="fas fa-list-ul"></i> Movimientos Recientes
            </h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaCambios"  class="table table-striped table-hover table-bordered" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha y Hora</th>
                            <th>Tabla Modificada</th>
                            <th>Usuario Responsable</th>
                            <th>Acción</th>
                            <th>Detalles</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.date.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@item.NombreTabla</td>
                                <td>

                                    @(item.usuario != null ? item.usuario.nombre + " " + item.usuario.apellido_1 : "Usuario No." + item.id_usuario)
                                </td>
                                <td>
                                    @* Aplicar colores a la acción (Added = Verde, Modified = Amarillo, Deleted = Rojo) *@
                                    @if (item.accion == "Added")
                                    {
                                        <span class="badge bg-success">Creación</span>
                                    }
                                    else if (item.accion == "Modified")
                                    {
                                        <span class="badge bg-warning text-dark">Modificación</span>
                                    }
                                    else if (item.accion == "Deleted")
                                    {
                                        <span class="badge bg-danger">Eliminación</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.accion</span>
                                    }
                                </td>
								<td>
									<button class="btn btn-info btn-sm"
											onclick="verDetalle('@Html.Raw(item.OldValues.Replace("'", "\\'"))', '@Html.Raw(item.NewValues.Replace("'", "\\'"))')">
										Ver
									</button>
								</td>

							</tr>
							<script>
								function verDetalle(oldValues, newValues) {
									Swal.fire({
						title: '📝 Cambios',
						html: "ANTES:\n" + oldValues + "\n\nDESPUÉS:\n" + newValues,
						icon: 'info',
						width: '800px',
						confirmButtonColor: '#5ABF8A',
						confirmButtonText: 'Cerrar',
						scrollable: true
					});
								}
							</script>
                        }
                    </tbody>
                </table>
            </div>
        </div>
	</div>
</div>

<script src="~/assets/js/ConsultarCambios.js"></script>

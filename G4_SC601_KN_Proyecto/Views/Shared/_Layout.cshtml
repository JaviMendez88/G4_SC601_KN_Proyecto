<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Inventory System web app</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- CSS -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/css/LineIcons.3.0.css" rel="stylesheet" />
    <link href="~/assets/css/animate.css" rel="stylesheet" />
    <link href="~/assets/css/tiny-slider.css" rel="stylesheet" />
    <link href="~/assets/css/glightbox.min.css" rel="stylesheet" />
    <link href="~/assets/css/main.css" rel="stylesheet" />
    <link href="~/assets/css/style.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.23.0/sweetalert2.css" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>

</head>

<body>
    <!-- ================= HEADER ================= -->
    <header class="header-clean">
        <div class="container">
            <nav class="navbar navbar-expand-lg">
                <a class="navbar-brand" href="@Url.Action("Index","Home")">
                    <img src="~/assets/images/logo/Terumo-logo-766x200.jpg" height="45" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="lni lni-menu"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Home")">Home</a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            @if (Session["IdUsuario"] != null && Convert.ToInt32(Session["Rol"] ?? 0) == 1)
                            {
                                <a class="nav-item ms-lg-3" href="@Url.Action("AdminDashboard", "Home")"> Acciones de Administrador</a>
                            }
                        </li>


                        @if (Session["IdUsuario"] != null)
                        {
                            <li class="nav-item ms-lg-3">
                                <a href="@Url.Action("UserDetail", "User")" class="signin"><i class="lni lni-user"></i> Mi Perfil</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a href="@Url.Action("Logout", "Home")" class="signup"><i class="lni lni-exit"></i> Cerrar Sesión</a>
                            </li>
                        }

                        else
                        {


                            <li class="nav-item ms-lg-3">
                                <a href="@Url.Action("Login","Home")" class="main-btn primary-btn-outline btn-sm">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a href="@Url.Action("Signup","Home")" class="main-btn primary-btn btn-sm">Registrarse</a>
                            </li>
                        }


                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <!-- ================= HERO (opcional) ================= -->
    @if (!IsSectionDefined("HideHero"))
    {
        <section class="hero-area">
            <div class="container">
                <h1 class="hero-title">Inventory Management - Smart App</h1>
                <div class="mt-4"></div>
            </div>
        </section>
    }

    <!-- ================= CONTENIDO ================= -->
    <main class="container auth-container">
        <div class="auth-box card-style">
            @RenderBody()
        </div>
    </main>

    <!-- ================= FOOTER ================= -->
    <footer class="footer-simple">
        <div class="container">
            <strong>Inventory Management - Smart Web App</strong><br />
            Universidad Fidélitas — Programación Avanzada SC604<br />
            Grupo 4 · © @DateTime.Now.Year
        </div>
    </footer>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Plugins de jQuery -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>

    <!-- Luego otros scripts -->
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/wow.min.js"></script>

    @RenderSection("Scripts", required: false)



    @RenderSection("Scripts", required: false)
</body>
</html>




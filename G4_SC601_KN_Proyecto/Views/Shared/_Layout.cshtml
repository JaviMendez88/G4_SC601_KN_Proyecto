
<!DOCTYPE html>
<html class="no-js" lang="zxx">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>Grupo 4 - Programación Avanzada</title>
    <meta name="description" content="" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" type="image/x-icon" href="assets/images/favicon.svg" />

    <!-- ========================= CSS here ========================= -->

    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/css/LineIcons.3.0.css" rel="stylesheet" />
    <link href="~/assets/css/animate.css" rel="stylesheet" />
    <link href="~/assets/css/tiny-slider.css" rel="stylesheet" />
    <link href="~/assets/css/glightbox.min.css" rel="stylesheet" />
    <link href="~/assets/css/main.css" rel="stylesheet" />
    <link href="~/assets/css/style.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
</head>




<body>
    <!-- Start Header Area -->
    <header class="header navbar-area">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12">
                    <div class="nav-inner">
                        <!-- Start Navbar -->
                        <nav class="navbar navbar-expand-lg">
                            <a class="navbar-brand" href="@Url.Action("Index","Home")">
                                <img src="~/assets/images/logo/Terumo-logo-766x200.jpg" />
                            </a>
                            
                            <div class="collapse navbar-collapse sub-menu-bar" id="navbarSupportedContent">
                                <ul id="nav" class="navbar-nav ms-auto">
                                    <li class="nav-item">
                                        <a class="dd-menu active collapsed" href="@Url.Action("Index","Home")" data-bs-toggle="collapse"
                                           data-bs-target="#submenu-1-1" aria-controls="navbarSupportedContent"
                                           aria-expanded="false" aria-label="Toggle navigation">Home</a>
                                    </li>
                                    
                                </ul>
                            </div>
                            <!--Perfil del usuario / Autenticación-->
                            <div class="button">
                                @if (Session["IdUsuario"] != null)
                                {
                                    <a href="@Url.Action("UserDetail", "User")" class="signin"><i class="lni lni-user"></i> Mi Perfil</a>
                                    <a href="@Url.Action("Logout", "Home")" class="signup"><i class="lni lni-exit"></i> Cerrar Sesión</a>
                                }
                                else
                                {
                                    <a href="@Url.Action("Login", "Home")" class="signin">Iniciar Sesión</a>
                                    <a href="@Url.Action("Signup", "Home")" class="signup">Registrarse</a>
                                }
                            </div>
                        </nav>
                        <!-- End Navbar -->
                    </div>
                </div>
            </div>
        </div>
    </header>
    <!-- Start Hero Area -->
    <div class="main-wrapper">
        @RenderBody()
    </div>


    <!-- ================= FOOTER ================= -->
    <footer class="footer-simple">
        <div class="container">
            <strong>Inventory Management - Smart Web App</strong><br />
            Universidad Fidélitas — Programación Avanzada SC604<br />
            Grupo 4 · © @DateTime.Now.Year
        </div>
    </footer>

    <a href="#" class="scroll-top">
        <i class="lni lni-chevron-up"></i>
    </a>

    <!-- ========================= JS here ========================= -->
    <script src="~/assets/js/bootstrap.min.js"></script>
    <script src="~/assets/js/count-up.min.js"></script>
    <script src="~/assets/js/glightbox.min.js"></script>
    <script src="~/assets/js/wow.min.js"></script>
    <script>


        var cu = new counterUp({
            start: 0,
            duration: 2000,
            intvalues: true,
            interval: 100,
            append: " ",
        });
        cu.start();
    </script>
</body>

</html>



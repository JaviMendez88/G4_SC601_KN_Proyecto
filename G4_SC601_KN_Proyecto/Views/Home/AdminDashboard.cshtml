@model G4_SC601_KN_Proyecto.Models.UsuarioModelo

@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    // --- RECUPERAMOS LOS DATOS DEL INVENTARIO ---
    var stock = ViewBag.StockInventario as IEnumerable<G4_SC601_KN_Proyecto.Models.StockViewModel>;
    var vencimientos = ViewBag.Vencimientos as IEnumerable<G4_SC601_KN_Proyecto.Models.StockViewModel>;
}

<div class="container-fluid mt-4">
    <h2 class="mb-3 text-gray-800">Bienvenido @Session["Nombre"]</h2>

    <div class="alert alert-success shadow-sm">
        ¡Has iniciado sesión correctamente!
    </div>

    <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-users"></i> Panel de Administrador
            </h5>


        </div>
        <div class="card-body">
            <h6 class="font-weight-bold text-secondary mb-3">Gestión de usuarios </h6>
            <ul class="mb-0">
                <li><a href="@Url.Action("ConsultarUsuarios","User")" class="text-decoration-none">Ver Usuarios</a></li>
            </ul>
        </div>
        <div class="card-body">
            <h6 class="font-weight-bold text-secondary mb-3">Gestión de materiales </h6>
            <ul class="mb-0">
                <li><a href="@Url.Action("ConsultMaterial","Material")" class="text-decoration-none">Ver Materiales</a></li>
            </ul>
        </div>

        <div class="card-body">
            <h6 class="font-weight-bold text-secondary mb-3">Auditoría de cambios </h6>
            <ul class="mb-0">
                <li><a href="@Url.Action("AuditoriaCambios","Auditoria")" class="text-decoration-none">Ver Cambios</a></li>

            </ul>
        </div>
    </div>

    <!-- Sección en proceso para la importación de archivos de Excel que alimenten las tablas de SQL (Stock) -->
    <!-- Ver [Post] en AdminController.cs ImportarExcel -->
    @Html.Partial("_AlertMessages")
    <div class="card shadow mb-4 border-left-success">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-success">
                <i class="fas fa-file-excel"></i> Importar inventario desde Excel
            </h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm(
                "ImportarExcel",
                "Admin",
                FormMethod.Post,
                new { enctype = "multipart/form-data" }))
            {
                <div class="form-group">
                    <input type="file"
                           name="archivoExcel"
                           class="form-control"
                           accept=".xlsx"
                           required />
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fas fa-upload"></i> Importar
                </button>
            }
        </div>
    </div>

    <!-- Ver comment arriba -->

    <hr class="my-5" />
    <h2 class="h4 mb-4 text-gray-800">Módulo de Inventarios</h2>

    <div class="mb-4">
        <a href="@Url.Action("RegistrarMovimiento", "Inventario")" class="btn btn-success shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Nuevo Movimiento (Entrada/Salida)
        </a>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold" style="color: #0056b3;">
                        <i class="fas fa-boxes"></i> Stock Actual
                    </h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" width="100%" cellspacing="0">
                            <thead class="table-dark">
                                <tr><th>Producto</th><th>Lote</th><th>Cantidad</th></tr>
                            </thead>
                            <tbody>
                                @if (stock != null)
                                {
                                    foreach (var item in stock)
                                    {
                                        <tr>
                                            <td>@item.Material</td>
                                            <td>@item.Lote</td>
                                            <td>
                                                @if (item.Cantidad < 50)
                                                {
                                                    <strong class="text-danger">@item.Cantidad (Bajo)</strong>
                                                }
                                                else
                                                {
                                                    <strong class="text-success">@item.Cantidad</strong>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted">No hay datos de stock disponibles. (Verifica el controlador)</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow mb-4" style="border-left: 4px solid #f6c23e;">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">
                        <i class="fas fa-exclamation-triangle"></i> Próximos Vencimientos
                    </h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="bg-warning text-dark">
                                <tr><th>Producto</th><th>Lote</th><th>Vence</th></tr>
                            </thead>
                            <tbody>
                                @if (vencimientos != null && vencimientos.Any())
                                {
                                    foreach (var item in vencimientos)
                                    {
                                        <tr>
                                            <td>@item.Material</td>
                                            <td>@item.Lote</td>
                                            <td class="text-danger font-weight-bold">@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-success">No hay alertas.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
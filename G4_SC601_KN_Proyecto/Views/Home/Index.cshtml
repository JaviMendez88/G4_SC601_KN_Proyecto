@{
    ViewBag.Title = "Home Page";
}

<section class="hero-area">
    <div class="main__circle"></div>

    <div class="main__circle3"></div>
    <div class="main__circle4"></div>

    <div class="container" style="max-width: 900px;">
        <div class="align-items-center">
            <div class="col-lg-6 col-md-12 col-12">
                <div class="hero-content">
                    <h1>
                        <span class="wow fadeInUp" data-wow-delay=".4s">Visión</span>
                        <span class="wow fadeInUp" data-wow-delay=".8s">del Grupo</span>

                    </h1>
                    <p>
                        El Grupo Terumo impulsa iniciativas estratégicas de sostenibilidad orientadas a abordar
                        desafíos clave en la atención médica, la sociedad y el medio ambiente global. Nuestro
                        compromiso es avanzar hacia un desarrollo responsable y sostenible, generando valor a
                        largo plazo mientras escuchamos activamente a nuestras partes interesadas.
                    </p>
                </div>
            </div>
            <div class="col-lg-6 col-md-12 col-12">
                <div class="app-image">
                    <div class="image-bg-shape"></div>
                    <img src="~/assets/images/logo/Terumo-edificio.jpg" />
                </div>
            </div>
        </div>
    </div>
</section>


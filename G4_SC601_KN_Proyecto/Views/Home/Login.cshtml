@model G4_SC601_KN_Proyecto.Models.UsuarioModelo

@{
    ViewBag.Title = "Log in";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<h4 class="text-center mb-4">Log in</h4>

@using (Html.BeginForm("Signin", "Home", FormMethod.Post))
{
    <div class="mb-3">
        <label class="form-label">Email</label>
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "email@example.com" })
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
    </div>

    <div class="d-grid mt-4">
        <button type="submit" class="btn btn-primary btn-lg w-100">Submit</button>
    </div>

    <p class="text-center mt-3 mb-0">
        Don't have an account?
        <a href="@Url.Action("Signup","Home")">Register</a>
    </p>

}
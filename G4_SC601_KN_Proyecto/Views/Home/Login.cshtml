@model G4_SC601_KN_Proyecto.Models.UsuarioModelo

@{
    ViewBag.Title = "Log in";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<h4 class="text-center mb-4">Log in</h4>

@using (Html.BeginForm("Login", "Home", FormMethod.Post))
{
    <div class="mb-3">
        <label class="form-label">Correo Electrónico</label>
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Correo Electrónico" })
    </div>

    <div class="mb-3">
        <label class="form-label">Contraseña</label>
        @Html.PasswordFor(m => m.Contrasena, new { @class = "form-control" })
    </div>

    <div class="d-grid mt-4">
        <button type="submit" class="btn btn-primary btn-lg w-100">Submit</button>
    </div>

    <p class="text-center mt-3 mb-0">
        No tiene una cuenta?
        <a href="@Url.Action("Signup","Home")">Registrarse</a>
    </p>

    <p class="text-center mt-3 mb-0">
        ¿Desea recuperar su contraseña?
        <a href="@Url.Action("AccountRecovery","Home")">Recuperación de cuenta</a>
    </p>

}
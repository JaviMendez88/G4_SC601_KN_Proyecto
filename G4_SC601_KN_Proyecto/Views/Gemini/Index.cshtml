@{
    ViewBag.Title = "Asistente Inteligente";
}

<div class="container mt-4">
    <div class="card shadow-lg" style="border-radius: 15px; border-color: #004a99;">
        <div class="card-header text-white" style="background-color: #004a99; border-radius: 15px 15px 0 0;">
            <h4 class="mb-0"><i class="fas fa-brain"></i> Asistente de Inventario Gemini</h4>
        </div>

        <div class="card-body" id="chatWindow" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;">
            <div class="alert alert-info" style="border-radius: 10px;">
                <strong>Gemini:</strong> ¡Hola! Soy tu asistente para el inventario de Terumo Neuro. ¿Sobre qué dispositivo médico o lote deseas consultar?
            </div>
        </div>

        <div class="card-footer" style="background-color: white; border-radius: 0 0 15px 15px;">
            <div class="input-group">
                <input type="text" id="userInput" class="form-control" placeholder="Escribe tu pregunta aquí..." onkeypress="manejarEnter(event)">
                <div class="input-group-append">
                    <button class="btn btn-primary" style="background-color: #004a99;" onclick="llamarIA()">
                        <i class="fas fa-paper-plane"></i> Enviar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function manejarEnter(e) {
            if (e.keyCode === 13) {
                llamarIA();
            }
        }

        function llamarIA() {
            var msg = $('#userInput').val();
            if(msg.trim() === "") return;

            $('#chatWindow').append('<div class="text-right mb-3">' +
                '<span style="background-color: #e9ecef; color: #212529; padding: 10px 15px; border-radius: 15px; display: inline-block; font-size: 14px; border: 1px solid #dee2e6;">' +
                '<strong>Tú:</strong> ' + msg + '</span></div>');

            $('#userInput').val('');
            $("#chatWindow").scrollTop($("#chatWindow")[0].scrollHeight);

            $.post('@Url.Action("Consultar", "Gemini")', { pregunta: msg }, function(data) {
                $('#chatWindow').append('<div class="text-left mb-3">' +
                    '<span style="background-color: #004a99; color: #ffffff; padding: 10px 15px; border-radius: 15px; display: inline-block; font-size: 14px; max-width: 80%; shadow: 2px 2px 5px rgba(0,0,0,0.1);">' +
                    '<strong>Gemini:</strong> ' + data.respuesta + '</span></div>');

                $("#chatWindow").scrollTop($("#chatWindow")[0].scrollHeight);
            });
        }
    </script>
}
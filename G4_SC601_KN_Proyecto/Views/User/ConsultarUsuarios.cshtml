
@Model List<G4_SC601_KN_Proyecto.EntityFramework.usuario>


    @{
  
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }

    <div class="row">
        <div class="col-12">
            <div class="section-title mb-3">
                <h4>Usuarios</h4>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card-style">
                <table id="tablaUsuarios" class="table table-responsive">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Apellido </th>
                            <th>Usuario</th>
                            <th>Correo Electronico</th>
                          
                            <th>Intentos fallidos</th>
                            <th>Bloqueado </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.id_usuario</td>
                                <td>@item.nombre</td>
                                <td>@item.apellido_1</td>
                                <td>@item.usuario1</td>
                                <td>@item.email</td>
                               
                                <td>@item.intentos_fallidos</td>
                                
                                
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>


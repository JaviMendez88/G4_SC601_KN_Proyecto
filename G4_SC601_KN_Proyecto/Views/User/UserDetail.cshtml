@model G4_SC601_KN_Proyecto.Models.PerfilModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


    <h2>Bienvenido @Session["Nombre"]</h2>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Detalles del Perfil</h4>
                </div>
                <div class="card-body">
                    <p><strong>Nombre:</strong> @Model.Nombre</p>
                    <p><strong>Primer Apellido:</strong> @Model.Apellido1</p>
                    <p><strong>Usuario Login:</strong> @Model.UsuarioLogin</p>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Rol:</strong> @Model.RolUsuario</p>
                </div>
                <div class="card-footer">
                    @Html.ActionLink(
                    "Editar Perfil",   // linkText (Lo que ve el usuario)
                    "EditUser",        // actionName (Nombre del ActionResult)
                    "User",            // controllerName (Nombre del Controlador)
                    null,              // routeValues (No enviamos parámetros en la URL)
                    new { @class = "btn btn-primary" }
)
                </div>
            </div>
        </div>
    </div>



